{
  "info": {
    "name": "Assignment API Import Safe v2.0",
    "_postman_id": "fe32c3ca-9637-483d-9d88-55cd3096a9d7",
    "schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json"
  },
  "variables": [
    { "id": "baseUrl", "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "id": "token", "key": "token", "value": "" },
    { "id": "taskId", "key": "taskId", "value": "" },
    { "id": "categoryId", "key": "categoryId", "value": "" },
    { "id": "tagId", "key": "tagId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Sample User\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/profile"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    }
  ]
}
