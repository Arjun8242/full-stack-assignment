    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Store task id from create response', function () {",
                  "  const body = pm.response.json();",
                  "  const createdTaskId = body?.task?.id || body?.task?._id;",
                  "  pm.expect(createdTaskId, 'Task id should exist in response').to.be.a('string').and.not.empty;",
                  "  pm.collectionVariables.set('taskId', createdTaskId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Finish assignment\",\n  \"description\": \"Create Postman collection\",\n  \"dueDate\": \"2026-12-31T00:00:00.000Z\",\n  \"status\": \"pending\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks"
              ]
            },
            "description": "Create a new task."
          },
          "response": []
        },
